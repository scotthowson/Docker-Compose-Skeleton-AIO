# =============================================================================
#   Docker Compose Skeleton — Root Configuration
#   Copy this file to .env and customize for your environment
#
#   Every setting has a sensible default in .config/settings.cfg.
#   Only override values here that you want to change.
# =============================================================================


# ─── Directory Configuration ─────────────────────────────────────────────────
# Persistent data directory for container volumes (relative to each stack).
# Docker Compose resolves this relative to each stack's folder, so each stack
# gets its own self-contained App-Data directory:
#   Stacks/core-infrastructure/App-Data/
#   Stacks/media-services/App-Data/
# This keeps all data neatly organized per stack.
APP_DATA_DIR="./App-Data"


# ─── User Configuration ──────────────────────────────────────────────────────
# User/Group IDs for container file permissions
PUID=1000
PGID=1000


# ─── Network Configuration ───────────────────────────────────────────────────
# Primary domain for reverse proxy routing
PROXY_DOMAIN=example.com


# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC


# ─── Notification Configuration (NTFY) ───────────────────────────────────────
# Leave empty to disable push notifications
NTFY_URL=
SERVER_NAME="Docker Server"


# ─── Dashboard Configuration ─────────────────────────────────────────────────
# URLs used in notification action buttons (leave empty to omit)
PORTAINER_URL=
DASHBOARD_ICON_URL=


# ─── Backup Configuration ────────────────────────────────────────────────────
BACKUP_SOURCE_DIR=
BACKUP_DEST_DIR=
BACKUP_RETENTION_COUNT=6


# ─── Docker Compose Configuration ────────────────────────────────────────────
# auto = detect best available (docker compose v2 plugin preferred)
# v1   = force legacy docker-compose binary
# v2   = force docker compose plugin
DOCKER_COMPOSE_VERSION=auto

# Timeout for Docker operations (seconds)
DOCKER_TIMEOUT=300


# ─── Stack Configuration ─────────────────────────────────────────────────────
# Space-separated list of stack category directories under Stacks/
# Order defines startup sequence (shutdown is reversed automatically).
# Add, remove, or reorder to fit your environment. setup.sh creates
# directories for any categories listed here that don't yet exist.
DOCKER_STACKS="core-infrastructure networking-security monitoring-management development-tools media-services web-applications storage-backup communication-collaboration entertainment-personal miscellaneous-services"

# Stacks that trigger NTFY push notifications on start/stop (subset of above)
NOTIFICATION_STACKS="core-infrastructure web-applications communication-collaboration"


# ─── Startup Behavior ────────────────────────────────────────────────────────
# Continue starting remaining stacks even if one fails its healthcheck
CONTINUE_ON_FAILURE=true

# Skip --wait flag (don't wait for healthchecks during startup)
# When true, containers start without waiting for healthy status
SKIP_HEALTHCHECK_WAIT=false

# Delay between starting individual stacks (seconds)
SERVICE_START_DELAY=5

# Maximum time (seconds) to wait for a single stack to start
STACK_START_TIMEOUT=120

# Display ASCII art banners during startup/shutdown (disable for cron/headless)
SHOW_BANNERS=true

# Show detailed system information at startup
SHOW_SYSTEM_INFO=false


# ─── Stop Behavior ───────────────────────────────────────────────────────────
# Set to true to remove named volumes on stop (DESTRUCTIVE!)
REMOVE_VOLUMES_ON_STOP=false

# Delay between stopping stacks (seconds)
SERVICE_STOP_DELAY=10


# ─── Health Check ────────────────────────────────────────────────────────────
# Enable post-startup health check
ENABLE_POST_STARTUP_HEALTH_CHECK=true

# Seconds to wait before health check (let services stabilize)
HEALTH_CHECK_DELAY=10

# Include CPU/memory metrics in health reports
INCLUDE_RESOURCE_METRICS=false


# ─── Monitored Containers ────────────────────────────────────────────────────
# Comma-separated container names for NTFY health monitoring
CRITICAL_CONTAINERS=
IMPORTANT_CONTAINERS=


# ─── Image Update Behavior ───────────────────────────────────────────────────
# Use aggressive pruning (remove ALL unused images after updates)
# When false, only dangling and images older than 24h are pruned
AGGRESSIVE_IMAGE_PRUNE=false

# Send NTFY notification after image update cycle with summary
UPDATE_NOTIFICATION=true


# ─── Logging Configuration ───────────────────────────────────────────────────
# Log level: ERROR, WARNING, INFO, DEBUG, VERBOSE
LOG_LEVEL=INFO

# Color output mode: auto, always, never
COLOR_MODE=auto

# Maximum log file size before rotation (e.g., 10M, 50M)
LOG_MAX_SIZE=10M

# Number of rotated log files to keep
LOG_BACKUP_COUNT=12

# Days to retain log files
LOG_RETENTION_DAYS=90

# Environment profile: production, staging, testing, development
ENVIRONMENT=production


# ─── REST API Server ─────────────────────────────────────────────────────────
# Enable the built-in REST API for remote management (required for DCS-UI)
API_ENABLED=true

# Port and bind address for the API server
# Use 0.0.0.0 to listen on all interfaces (for remote access)
API_PORT=9876
API_BIND=0.0.0.0

# ─── DCS-UI (Web Interface) ─────────────────────────────────────────────────
# Port for the DCS-UI web interface (published to all interfaces)
# Set to 127.0.0.1:3000 to restrict to localhost only
DCS_UI_PORT=3000


# ─── Container Management ────────────────────────────────────────────────────
# Remove orphaned containers during startup cleanup
REMOVE_ORPHANED_CONTAINERS=true

# Force recreate containers on every start (not recommended for production)
FORCE_RECREATE=false

# Maximum parallel Docker operations
MAX_PARALLEL_OPERATIONS=3


# ─── Metrics & Trending ────────────────────────────────────────────────────
# Enable persistent metrics collection for historical trends
METRICS_ENABLED=true

# Interval between metric samples (seconds)
METRICS_COLLECT_INTERVAL=30

# Days to retain historical metrics data
METRICS_RETENTION_DAYS=7


# ─── Rollback System ───────────────────────────────────────────────────────
# Auto-snapshot stacks before operations for rollback capability
ROLLBACK_ENABLED=true

# Maximum snapshots to keep per stack
ROLLBACK_MAX_SNAPSHOTS=10


# ─── Secrets Management ────────────────────────────────────────────────────
# Encrypt secrets at rest (uses AES-256-CBC with auto-generated master key)
SECRETS_ENCRYPTION=true


# ─── Scheduled Operations ──────────────────────────────────────────────────
# Enable background scheduler for automated tasks (backup, prune, etc.)
SCHEDULER_ENABLED=false


# ─── Plugins ───────────────────────────────────────────────────────────────
# Enable the plugin extension system
PLUGINS_ENABLED=true

# Allow plugins to run hooks on system events
PLUGINS_HOOKS_ENABLED=true


# ─── Health Scoring ────────────────────────────────────────────────────────
# Enable health scoring (0-100 scores for containers, stacks, system)
HEALTH_SCORE_ENABLED=true


# ─── Structured Logging ────────────────────────────────────────────────────
# Enable JSONL structured log output alongside plain text logs
ENABLE_STRUCTURED_LOGGING=true
